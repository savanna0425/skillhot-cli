{
  "name": "skillhot-toolkit",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:catalog": "pnpm --filter @skillhot/core build && node scripts/build-catalog.mjs",
    "build": "pnpm --filter @skillhot/core build && pnpm --filter @skillhot/cli build",
    "check": "pnpm typecheck && pnpm test && pnpm validate:skill && pnpm validate:catalog && pnpm build && pnpm smoke:pack",
    "smoke:pack": "node scripts/verify-packed-cli.mjs",
    "test": "pnpm --filter @skillhot/core test && pnpm --filter @skillhot/cli test && node scripts/validate-skill.test.mjs && node --test scripts/verify-typecheck-order.test.mjs",
    "typecheck": "pnpm --filter @skillhot/core build && pnpm --filter @skillhot/cli typecheck",
    "validate:catalog": "pnpm --filter @skillhot/core build && node scripts/validate-catalog.mjs",
    "validate:skill": "node scripts/validate-skill.mjs skills/skillhot-discovery/SKILL.md"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "typescript": "^5.8.3"
  }
}
