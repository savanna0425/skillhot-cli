{
  "name": "@skillhot/core",
  "version": "0.1.0",
  "description": "Dependency-free catalog schema and discovery core for SkillHot.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/savanna0425/skillhot-cli.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "pnpm run build && node --test dist/test/*.test.js",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  }
}
